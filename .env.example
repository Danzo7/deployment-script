# Base directory for all applications (default: <root>/.applications)
# APP_DIR=/opt/apps

# Override per project type (default: APP_DIR)
# NEXT_DIR=/opt/apps/next
# NEST_DIR=/opt/apps/nest
# DOTNET_DIR=/opt/apps/dotnet

# Directory for persistent storage volumes (default: APP_DIR/storages)
# STORAGE_DIR=/opt/apps/storages

# Directory where domain nginx configs are written (default: <root>/.domains)
# DOMAINS_DIR=/etc/nginx/sites-available

# Hostname or IP nginx proxies to (default: localhost)
# PROXY_TARGET_HOST=127.0.0.1

# Target directory for SSL certificates during push operations
# Local deployment: If set, copies certs to PUSH_CERT_DIR/<domain>/ and rewrites nginx config paths
#                  If not set, uses cert paths from DB as-is (assumes same machine)
# Remote deployment: Defaults to /etc/nginx/ssl if not set
# PUSH_CERT_DIR=/etc/ssl/certs/myapp

# Remote Nginx host for domain push operations (format: user@host)
# If not set, push operations target local Nginx installation
# NGINX_REMOTE_HOST=deploy@nginx.example.com

# SSH private key path for remote Nginx operations (default: ~/.ssh/id_rsa)
# NGINX_REMOTE_KEY=/path/to/custom/key

# SSH password for remote Nginx operations (fallback if NGINX_REMOTE_KEY is not set)
# Also used as sudo password by default unless NGINX_SUDO_PASSWORD is explicitly set
# NGINX_REMOTE_PASSWORD=your_password_here

# Sudo password for nginx commands on remote host (optional - defaults to NGINX_REMOTE_PASSWORD)
# Only set this if your sudo password is different from your SSH password
# NGINX_SUDO_PASSWORD=your_sudo_password_here
